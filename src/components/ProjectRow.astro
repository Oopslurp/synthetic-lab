---
import { url } from '../lib/paths';

interface Props {
  numero: string;
  slug: string;
  titre: string;
  categorie: string;
  periode: string;
  statut: 'termine' | 'en-cours';
}

const { numero, slug, titre, categorie, periode, statut } = Astro.props;
---

<a class="row" href={url(`/projets/${slug}/`)} data-reveal>
  <span class="numero mono-label">{numero}</span>
  <span class="titre">{titre}</span>
  <span class="categorie">{categorie}</span>
  <span class="meta">
    <span class="mono-label periode">{periode}</span>
    <span class={statut === 'en-cours' ? 'statut statut--en-cours' : 'statut'}>
      {statut === 'en-cours' ? 'En cours' : 'Terminé'}
    </span>
  </span>
  <span class="fleche" aria-hidden="true">→</span>
</a>

<style>
  .row {
    display: grid;
    grid-template-columns: 3.4rem 1.25fr 1fr auto 2.2rem;
    align-items: center;
    gap: 1.2rem;
    padding: 1.55rem 0.9rem;
    border-top: 1px solid var(--line);
    text-decoration: none;
    transition: background-color 0.35s var(--ease);
  }
  .row:last-of-type { border-bottom: 1px solid var(--line); }
  .row:hover { background: var(--accent-soft); }
  .numero { color: var(--accent); }
  .titre {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    letter-spacing: -0.02em;
    transition: color 0.3s var(--ease);
  }
  .row:hover .titre { color: var(--accent); }
  .categorie { color: var(--muted); font-size: 0.92rem; }
  .meta {
    display: flex;
    align-items: center;
    gap: 1.3rem;
    white-space: nowrap;
  }
  .fleche {
    justify-self: end;
    font-size: 1.15rem;
    color: var(--muted);
    transition: transform 0.35s var(--ease), color 0.35s var(--ease);
  }
  .row:hover .fleche { transform: translateX(6px); color: var(--accent); }

  @media (max-width: 760px) {
    .row {
      grid-template-columns: 3rem 1fr 2rem;
      grid-template-areas:
        'numero titre fleche'
        'numero categorie fleche'
        'numero meta fleche';
      row-gap: 0.35rem;
      padding: 1.3rem 0.4rem;
    }
    .numero { grid-area: numero; }
    .titre { grid-area: titre; }
    .categorie { grid-area: categorie; }
    .meta { grid-area: meta; gap: 1rem; margin-top: 0.3rem; }
    .fleche { grid-area: fleche; }
    .periode { letter-spacing: 0.08em; }
  }
</style>
